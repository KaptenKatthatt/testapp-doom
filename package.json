{
  "name": "testapp-doom",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm-run-all lint typecheck type-coverage",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --build --noEmit",
    "type-coverage": "type-coverage -p ./tsconfig.app.json --at-least 100"
  },
  "dependencies": {
    "@react-three/fiber": "^9.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.177.0",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.28.0",
    "npm-run-all": "^4.1.5",
    "type-coverage": "^2.29.7",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.0"
  }
}
